# Alpaca Paper Trading (new paper account, separate from the swing agent)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Capital
MAX_CAPITAL=2000

# Intraday risk parameters
MAX_RISK_PER_TRADE=0.01
MAX_TOTAL_RISK=0.20
MAX_OPEN_POSITIONS=20
DEFAULT_RR_RATIO=1.5
ATR_SL_MULTIPLIER=1.0

# Scanner — 15-minute bars, rescan every 5 minutes during market hours
SCANNER_ENABLED=true
SCANNER_BAR_MINUTES=15
SCANNER_LOOKBACK_DAYS=10
SCANNER_INTERVAL_SECONDS=300

# Intraday session guardrails (US Eastern time)
INTRADAY_NO_NEW_TRADES_HOUR=15
INTRADAY_NO_NEW_TRADES_MINUTE=0
INTRADAY_FORCE_CLOSE_HOUR=15
INTRADAY_FORCE_CLOSE_MINUTE=55

# Database (Railway auto-injects DATABASE_URL from the linked Postgres
# service; the value below is only the SQLite fallback for local dev)
DATABASE_URL=sqlite+aiosqlite:///./trading_agent_intraday.db
